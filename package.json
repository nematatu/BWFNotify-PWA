{
	"name": "bwfnotify-pwa",
	"version": "1.0.0",
	"private": true,
	"description": "PWA notifications for live BWF matches involving Japanese players.",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "WRANGLER_LOG_PATH=.wrangler/logs wrangler dev --test-scheduled",
		"deploy": "wrangler deploy",
		"dry-run": "WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy --dry-run",
		"types": "wrangler types",
		"typecheck": "tsc --noEmit",
		"test": "bun run test:unit && bun run test:integration",
		"test:unit": "bun test ./test/",
		"test:integration": "WRANGLER_LOG_PATH=.wrangler/logs vitest run --config vitest.config.ts",
		"test:layout": "playwright test",
		"lint": "biome check .",
		"check": "bun run typecheck && bun run lint && bun run test",
		"precommit": "bun run check && bun run test:layout && bun run dry-run",
		"format": "biome check --write .",
		"generate:vapid": "web-push generate-vapid-keys --json"
	},
	"dependencies": {
		"hono": "^4.12.30",
		"web-push": "^3.6.7"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@cloudflare/vitest-pool-workers": "^0.18.6",
		"@playwright/test": "^1.61.1",
		"@types/node": "^26.1.1",
		"@types/web-push": "^3.6.4",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0",
		"wrangler": "^4.112.0"
	}
}
