{
	"name": "bwfnotify-pwa",
	"version": "1.0.0",
	"private": true,
	"description": "PWA notifications for live BWF matches involving Japanese players.",
	"homepage": "https://bwfnotify-pwa.amtt.workers.dev/",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nematatu/BWFNotify-PWA.git"
	},
	"bugs": {
		"url": "https://github.com/nematatu/BWFNotify-PWA/issues"
	},
	"keywords": [
		"badminton",
		"bwf",
		"cloudflare-workers",
		"pwa",
		"web-push"
	],
	"license": "MIT",
	"packageManager": "bun@1.3.14",
	"engines": {
		"bun": ">=1.3.14"
	},
	"type": "module",
	"scripts": {
		"dev": "bun scripts/dev.mjs",
		"build": "vite build",
		"deploy": "bun run build && wrangler deploy",
		"dry-run": "bun run build && WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy --dry-run",
		"types": "wrangler types",
		"types:check": "WRANGLER_LOG_PATH=.wrangler/logs wrangler types --check",
		"typecheck": "tsc --noEmit",
		"test": "bun run test:unit && bun run test:integration",
		"test:unit": "bun test ./test/",
		"test:integration": "WRANGLER_LOG_PATH=.wrangler/logs vitest run --config vitest.config.ts",
		"test:layout": "bun run build && playwright test",
		"test:dev-pwa": "playwright test --config playwright.dev.config.ts",
		"lint": "biome check .",
		"check": "bun run types:check && bun run typecheck && bun run lint && bun run test",
		"precommit": "bun run check && bun run test:layout && bun run test:dev-pwa && bun run dry-run",
		"format": "biome check --write .",
		"generate:vapid": "web-push generate-vapid-keys --json",
		"update:calendar": "bun scripts/update-baj-calendar.ts",
		"prepare": "husky"
	},
	"dependencies": {
		"hono": "^4.12.30",
		"lucide-solid": "^1.25.0",
		"solid-js": "^1.9.14",
		"unpdf": "^1.6.2",
		"web-push": "^3.6.7"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@cloudflare/vitest-pool-workers": "^0.18.6",
		"@playwright/test": "^1.61.1",
		"@types/node": "^26.1.1",
		"@types/web-push": "^3.6.4",
		"husky": "^9.1.7",
		"linkedom": "^0.18.13",
		"typescript": "^7.0.2",
		"vite": "^8.1.5",
		"vite-plugin-solid": "^2.11.13",
		"vitest": "^4.1.0",
		"wrangler": "^4.112.0"
	}
}
