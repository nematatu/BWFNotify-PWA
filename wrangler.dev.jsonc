{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "bwfnotify-pwa-dev-api",
	"main": "src/api/development.ts",
	"compatibility_date": "2026-07-17",
	"compatibility_flags": ["nodejs_compat"],
	"secrets": {
		"required": ["VAPID_PUBLIC_KEY", "VAPID_PRIVATE_KEY", "VAPID_SUBJECT"]
	},
	"kv_namespaces": [
		{
			"binding": "NOTIFIED_MATCHES",
			"id": "2099ab6e1ad94bfea30573265cd4d75e",
			"preview_id": "5cc23ea8239d43d2b656a848cdbdc1dd"
		}
	]
}
