{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"jsx": "preserve",
		"jsxImportSource": "solid-js"
	},
	"include": ["worker-configuration.d.ts", "src/**/*.ts", "src/**/*.tsx"]
}
